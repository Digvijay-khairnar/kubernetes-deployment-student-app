
# Step 1: helm instalation

# Helm now has an installer script that will automatically grab the latest version of Helm and install it locally.

# You can fetch that script, and then execute it locally. It's well documented so that you can read through it and understand what it is doing before you run it.

# link / script 

# These commands are used to download, make executable, and run the Helm installation script.

curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-4
chmod 700 get_helm.sh
./get_helm.sh


# run this 
# This command downloads and extracts the latest eksctl binary for Linux/macOS directly from GitHub.

curl --silent --location "https://github.com/weaveworks/eksctl/releases/latest/download/eksctl_$(uname -s)_amd64.tar.gz" | tar xz -C /tmp

sudo mv /tmp/eksctl /usr/local/bin

eksctl version


# oidc-provider

# This command associates an IAM OIDC (OpenID Connect) provider with your Amazon EKS cluster.

eksctl utils associate-iam-oidc-provider \
  --cluster my-eks \
  --region eu-north-1 \
  --approve



# This command creates a Kubernetes ServiceAccount and an associated IAM Role for the Amazon EBS CSI Driver using IRSA (IAM Roles for Service Accounts).
# Create IAM Service Account

eksctl create iamserviceaccount \
  --name ebs-csi-controller-sa \
  --namespace kube-system \
  --cluster my-eks \
  --role-name AmazonEKS_EBS_CSI_DriverRole \
  --region eu-north-1 \
  --override-existing-serviceaccounts \
  --attach-policy-arn arn:aws:iam::aws:policy/service-role/AmazonEBSCSIDriverPolicy \
  --approve
# Step 2: Install AWS EBS CSI Driver

# Add Helm Repository
# This command adds the AWS EBS CSI Driver Helm chart repository to your local Helm configuration.

helm repo add aws-ebs-csi-driver https://kubernetes-sigs.github.io/aws-ebs-csi-driver
helm repo update

# It connects your EKS cluster with AWS IAM using OIDC (OpenID Connect), so Kubernetes pods can assume IAM roles securely.

eksctl utils associate-iam-oidc-provider --region=eu-north-1 --cluster=my-eks --approve



# Install EBS CSI Driver


helm upgrade --install aws-ebs-csi-driver \
  aws-ebs-csi-driver/aws-ebs-csi-driver \
  --namespace kube-system \
  --set controller.serviceAccount.create=false \
  --set controller.serviceAccount.name=ebs-csi-controller-sa


 # Verify Installation

# Check if pods are running

kubectl get pods -n kube-system -l app.kubernetes.io/name=aws-ebs-csi-driver

# Check CSI drivers

kubectl get csidrivers

